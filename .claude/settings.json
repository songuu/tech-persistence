{
    "$schema":  "https://code.claude.com/schemas/settings.json",
    "autoMemoryEnabled":  true,
    "hooks":  {
                  "SessionStart":  [
                                       {
                                           "matcher":  "*",
                                           "hooks":  [
                                                         {
                                                             "type":  "command",
                                                             "command":  "node \"C:/Users/Administrator/.claude/skills/continuous-learning/hooks/inject-context.js\" 2\u003enul || exit /b 0",
                                                             "timeout":  5000
                                                         }
                                                     ]
                                       }
                                   ],
                  "PreToolUse":  [
                                     {
                                         "matcher":  "*",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "node \"C:/Users/Administrator/.claude/skills/continuous-learning/hooks/observe.js\" pre 2\u003enul || exit /b 0",
                                                           "timeout":  2000
                                                       }
                                                   ]
                                     }
                                 ],
                  "PostToolUse":  [
                                      {
                                          "matcher":  "*",
                                          "hooks":  [
                                                        {
                                                            "type":  "command",
                                                            "command":  "node \"C:/Users/Administrator/.claude/skills/continuous-learning/hooks/observe.js\" post 2\u003enul || exit /b 0",
                                                            "timeout":  2000
                                                        }
                                                    ]
                                      }
                                  ],
                  "Stop":  [
                               {
                                   "matcher":  "*",
                                   "hooks":  [
                                                 {
                                                     "type":  "command",
                                                     "command":  "node \"C:/Users/Administrator/.claude/skills/continuous-learning/hooks/evaluate-session.js\" 2\u003enul || exit /b 0",
                                                     "timeout":  10000
                                                 }
                                             ]
                               }
                           ]
              }
}
