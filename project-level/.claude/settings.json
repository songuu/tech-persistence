{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(.claude/**)",
      "Write(docs/tech-learnings/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/skills/continuous-learning/hooks/inject-context.js 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/skills/continuous-learning/hooks/observe.js pre 2>/dev/null || true",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/skills/continuous-learning/hooks/observe.js post 2>/dev/null || true",
            "timeout": 2000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/skills/continuous-learning/hooks/evaluate-session.js 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
