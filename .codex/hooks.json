{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/guard-handoff-path.js",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "node scripts/observe.js pre 2>/dev/null || true",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/observe.js post 2>/dev/null || true",
            "timeout": 2000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/inject-context.js 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/evaluate-session.js 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
