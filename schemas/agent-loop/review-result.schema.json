{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tech-persistence.local/schemas/agent-loop/review-result.schema.json",
  "title": "Agent Loop Review Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "decision",
    "compliant",
    "findings",
    "followUpTasks"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["approved", "changes_requested", "blocked"]
    },
    "compliant": { "type": "boolean" },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["severity", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "message": { "type": "string" },
          "requiredFix": { "type": "string" }
        }
      }
    },
    "followUpTasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clarificationRulings": {
      "type": "array",
      "description": "Optional. Rulings for open clarifications raised by the implementer. decision=confirm-assumption keeps the adopted assumption; decision=revise-spec means the spec must change (also surface the change in findings/followUpTasks so the classic needs-followup loop re-implements).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "decision"],
        "properties": {
          "id": { "type": "string" },
          "decision": {
            "type": "string",
            "enum": ["confirm-assumption", "revise-spec"]
          },
          "note": { "type": "string" }
        }
      }
    }
  }
}
