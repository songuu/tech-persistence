{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tech-persistence.local/schemas/agent-loop/global-contract.schema.json",
  "title": "Agent Loop Pipeline Global Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "goal",
    "nonGoals",
    "globalAcceptance",
    "architectureConstraints",
    "runtimeTargets",
    "riskLevel",
    "blockingQuestions"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["global-v1"]
    },
    "goal": { "type": "string" },
    "nonGoals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "globalAcceptance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "architectureConstraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "runtimeTargets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude-code", "codex"]
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "blockingQuestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "integrationValidationCommands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contractHash": { "type": "string" }
  }
}
